{
  "uid": "nexus-app-replicas",
  "title": "Nexus App - Desired vs Running",
  "tags": ["nexus", "replicas"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Desired vs Available Replicas",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "refId": "A",
          "expr": "kube_deployment_spec_replicas{namespace=\"nexus\",deployment=\"nexus-app\"}",
          "legendFormat": "desired"
        },
        {
          "refId": "B",
          "expr": "kube_deployment_status_replicas_available{namespace=\"nexus\",deployment=\"nexus-app\"}",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}